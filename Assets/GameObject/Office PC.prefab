    content: "\u0426\u0435\u043D\u0430 \u043F\u043E\u043A\u0443\u043F\u043A\u0438:
      1000\n\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043F\u043E\u043A\u0443\u043F\u043A\u0443
      \u041E\u0444\u0438\u0441\u043D\u043E\u0433\u043E \u043F\u043A!\n\n\u0414\u0430\u043D\u043D\u044B\u0439
      \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 \u043C\u043E\u0436\u043D\u043E
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0432:\n1.
      \u041F\u0435\u0447\u0430\u0442\u0430\u043D\u044C\u0435 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u043E\u0432\n2.
      \u0421\u0451\u0440\u0444\u0438\u043D\u0433 \u043F\u043E \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0443\n3.
      \u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0444\u0430\u0439\u043B\u0430\u043C\u0438.\n\u0414\u043B\u044F
      \u0434\u0430\u043D\u043D\u044B\u0445 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439
      \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u043E \u0441\u043F\u0435\u0446\u0430\u043B\u044C\u043D\u043E\u0435
      \n\u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u043E\u0435 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u0435.
      \u0414\u043B\u044F \u0434\u0440\u0443\u0433\u0438\u0445 \u0441\u0446\u0435\u043D\u0430\u0440\u0438\u0435\u0432
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F,
